{
    "compilerOptions":
    {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "outDir": "./dist",
        "noEmit": true,
        "allowJs": true,
        "checkJs": true,
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "strict": true
    },
    "include":
    [
        "packages/**/*.js",
        "packages/**/*.json",
        "apps/**/*.js",
        "apps/**/*.json",
        "services/**/*.js",
        "services/**/*.json"
    ],
    "exclude":
    [
        "node_modules",
        "dist",
        ".vscode"
    ]
}